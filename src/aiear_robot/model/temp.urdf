<robot name="four_wheeled_diff_drive_robot">
  <!-- Step 1: Defining Geometry and Constants -->
  <!-- <xacro:property name="pi" value="3.14159265" /> -->
  <!-- Moments of intertia -->
  <!-- mu1 and mu2 are friction coeficients -->
  <gazebo reference="body_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="wheel1_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="wheel2_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="caster_link">
    <mu1>0.000002</mu1>
    <mu2>0.000002</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>
  <!-- Controller for the differential Drive robot -->
  <gazebo>
    <!-- Joint State publisher -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <!-- All these parameters are from the gz-sim-diff-drive-system pkg ...youre just required to pass your arguments  -->
      <!-- wheels -->
      <right_joint>wheel1_joint</right_joint>
      <left_joint>wheel2_joint</left_joint>
      <!-- kinematics -->
      <wheel_separation>0.7</wheel_separation>
      <wheel_diameter>0.3</wheel_diameter>
      <!-- limits -->
      <max_linear_acceleration>10</max_linear_acceleration>
      <!-- topic, frames and odometry -->
      <topic>cmd_vel</topic>
      <tf_topi>/tf</tf_topi>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel1_joint</joint_name>
      <joint_name>wheel2_joint</joint_name>
    </plugin>
  </gazebo>
  <!-- Defining the links and joints -->
  <!-- Fictious link of the robot -->
  <link name="base_footprint">
    <!-- theres nothing in here ecause this is a fabricated link and is not part of the robot ...its more like a reference frame -->
  </link>
  <!-- Between every two links, there is a joint we need to define -->
  <!-- in our case here the twolinks are the base_footprint(fictious link) and the body_link of the robot -->
  <joint name="body_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
  </joint>
  <!-- ############################################## -->
  <!-- START BODY LINK OF THE ROBOT -->
  <!-- ############################################### -->
  <link name="body_link">
    <visual>
      <origin rpy="0 0 0.3" xyz="0 0 0"/>
      <geometry>
        <box size="1.0 0.6 0.3"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0.3" xyz="0 0 0"/>
      <geometry>
        <box size="1.0 0.6 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Displacement and orientation of center of mass frame of the link with repect to the fixed "world" -->
      <origin rpy="0 0 0" xyz="0 0 0.3"/>
      <mass value="487.79999999999995"/>
      <inertia ixx="18.292499999999993" ixy="0.0" ixz="0.0" iyy="44.308499999999995" iyz="0.0" izz="55.283999999999985"/>
    </inertial>
  </link>
  <!-- ############################################## -->
  <!-- END BODY LINK OF THE ROBOT -->
  <!-- ############################################### -->
  <!-- ############################################## -->
  <!-- START Wheel links of Robot and their joints -->
  <!-- ############################################### -->
  <!-- Joint btn wheel 1 and body link -->
  <joint name="wheel1_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel1_link"/>
    <origin rpy="0 0 0" xyz="-0.3 -0.35 0.15"/>
    <axis xyz="0 1 0"/>
    <!-- This one determins in which axis is your link performing the motion -->
    <limit effort="50000" velocity="10"/>
    <!-- Effort = max Torque vel = max vel -->
    <dynamics damping="1.0" friction="1.0"/>
  </joint>
  <!-- Wheel 1 link -->
  <link name="wheel1_link">
    <visual>
      <origin rpy="0 0 0" xyz="1.570795 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="1.570795 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <mass value="19.15586120526376"/>
      <inertia ixx="0.12371493695066177" ixy="0.0" ixz="0.0" iyy="0.12371493695066177" iyz="0.0" izz="0.2155034385592173"/>
    </inertial>
  </link>
  <!-- Joint btn wheel 2 and body link -->
  <joint name="wheel2_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel2_link"/>
    <origin rpy="0 0 0" xyz="0.3 0.35 0.15"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamic damping="1.0" friction="1.0"/>
  </joint>
  <!-- Wheel 2 link -->
  <link name="wheel2_link">
    <visual>
      <origin rpy="0 0 0" xyz="1.570795 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="1.570795 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <mass value="19.15586120526376"/>
      <inertia ixx="0.12371493695066177" ixy="0.0" ixz="0.0" iyy="0.12371493695066177" iyz="0.0" izz="0.2155034385592173"/>
    </inertial>
  </link>
  <!-- ############################################## -->
  <!-- End Wheel links of Robot and their joints -->
  <!-- ############################################### -->
  <!-- ############################################## -->
  <!-- START Caster link of Robot and joint -->
  <!-- ############################################### -->
  <joint name="caster_joint" type="fixed">
    <parent link="body_link"/>
    <child link="caster_link"/>
    <origin rpy="0 0 0" xyz="0.3 0 0.15"/>
  </joint>
  <link name="caster_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="38.31172241052752"/>
      <inertia ixx="0.3448055016947477" ixy="0.0" ixz="0.0" iyy="0.3448055016947477" iyz="0.0" izz="0.3448055016947477"/>
    </inertial>
  </link>
</robot>
